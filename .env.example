# Скопируй в .env и заполни. На Railway/Render задаёшь это в разделе Variables.

# Токен бота из @BotFather (обязательно)
BOT_TOKEN=

# Адрес курса на Netlify — он откроется как Mini App
COURSE_URL=https://your-course.netlify.app

# Твой chat_id (узнать: запусти бота и отправь команду /id)
ADMIN_CHAT_ID=

# Google-таблица через Apps Script (если пусто — пишется в локальный progress.json)
# URL веб-приложения из Apps Script (Deploy → Web app, заканчивается на /exec)
APPS_SCRIPT_URL=
# Секрет, общий с apps-script.gs (защищает эндпоинт от чужих запросов)
APPS_SCRIPT_SECRET=

# Порт HTTP-API (Railway/Render подставят свой автоматически)
PORT=8080

# Час ежедневной рассылки напоминаний (по МСК). По умолчанию 10.
REMINDER_HOUR=10

# Чат кураторов (id): туда падают вопросы и ежедневная сводка «кому напомнить»
# по веб-пользователям (у кого нет Telegram — им куратор пишет письмо сам).
# Если не задан — берётся ADMIN_CHAT_ID.
CURATORS_CHAT_ID=
